# Server Environment Variables
# These variables are used by the Node.js backend.

# Port the server will listen on.
PORT=5000

# Node environment (e.g., development, production, test).
NODE_ENV=development

# MongoDB connection URI. Replace with your actual MongoDB connection string.
# For local development with Docker or a local MongoDB instance:
# MONGODB_URI=mongodb://localhost:27017/recipebook
# For MongoDB Atlas or other cloud providers:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/recipebook?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/recipebook

# Secret key for signing JSON Web Tokens (JWTs).
# Generate a strong, random string for production.
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# Expiration time for JWTs (e.g., 1h, 24h, 7d).
JWT_EXPIRES_IN=1h

# External Recipe API Configuration (e.g., Edamam, Spoonacular, etc.)
# Replace with the base URL, App ID, and App Key for your chosen API.
# Example for Edamam:
EXTERNAL_API_BASE_URL=https://api.edamam.com/api/recipes/v2
EXTERNAL_API_APP_ID=your_external_api_app_id
EXTERNAL_API_APP_KEY=your_external_api_app_key

# Client Environment Variables
# These variables are used by the React frontend.
# They must be prefixed with REACT_APP_ to be exposed to the browser.

# Base URL for the backend API that the React app will communicate with.
# In development, this will typically point to your local Node.js server.
# In production, this should be the URL of your deployed backend.
REACT_APP_API_BASE_URL=http://localhost:5000/api